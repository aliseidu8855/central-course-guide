# ============================================================
# Central Course Guide — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit real credentials to version control.
# ============================================================

MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=central_course_guide

# NVIDIA NIM API key (free tier — sign up at build.nvidia.com)
# The course Q&A chatbot won't work without this.
NVIDIA_API_KEY=
